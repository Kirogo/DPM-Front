# Production Environment Configuration
# Copy this file to .env.production and update with production values

# Backend API Configuration (update with your production domain)
VITE_API_URL=https://api.yourdomain.com/api
VITE_SIGNALR_URL=https://api.yourdomain.com/hub

# Google Maps Configuration
VITE_MAPS_API_KEY=your_google_maps_production_key

# Feature Flags
VITE_ENABLE_GEOTAGGING=true

# File Size Limits (in bytes)
VITE_MAX_PHOTO_SIZE=10485760

# Application Metadata
VITE_APP_NAME=GeoBuild
VITE_APP_VERSION=1.0.0
